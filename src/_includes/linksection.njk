{% macro linkSection(links, title=null, lang=null) %}
<section class="link-group"{% if lang %} lang="{{ lang }}"{% endif %}>
  {% if title %}<h2 class="link-group__title">{{ title }}</h2>{% endif %}
  <nav class="links" aria-label="{{ title if title else 'Links' }}">
    {% for link in links %}
    <a class="link" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
      <span class="link__label">{{ link.label }}</span>
      <span class="visually-hidden">(opens in a new tab)</span>
      <svg class="link__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </a>
    {% endfor %}
  </nav>
</section>
{% endmacro %}
